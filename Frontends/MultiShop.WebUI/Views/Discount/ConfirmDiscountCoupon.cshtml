
<div>
    <!-- Kupon Formu -->
    <form class="mb-3"
          asp-controller="Discount"
          asp-action="ConfirmDiscountCoupon"
          method="post">
        <div class="input-group">
            <input type="text"
                   name="CouponCode"
                   value="@TempData["CouponCode"]"
                   class="form-control border-0 p-4"
                   placeholder="Kupon Kodunuz" />

            <div class="input-group-append">
                <button class="btn btn-primary">Kuponu Uygula</button>
            </div>
        </div>
    </form>

    <!-- Kupon Mesajları -->
    @if (TempData["CouponError"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["CouponError"]
        </div>
    }

    @if (TempData["CouponSuccess"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["CouponSuccess"]
        </div>
    }

    <h5 class="section-title position-relative text-uppercase mb-3">
        <span class="bg-secondary pr-3">Sipariş Özeti</span>
    </h5>

    <div class="bg-light p-30 mb-5">
        <div class="border-bottom pb-2">

            <div class="d-flex justify-content-between mb-2">
                <h6>Toplam Ürün Fiyatı</h6>
                <h6>@ViewBag.total ₺</h6>
            </div>

            <div class="d-flex justify-content-between mb-2">
                <h6>KDV (%10)</h6>
                <h6>@ViewBag.tax ₺</h6>
            </div>

            <div class="d-flex justify-content-between mb-2">
                <h6>Toplam</h6>
                <h6>@ViewBag.totalPriceWithTax ₺</h6>
            </div>

            @if (TempData["DiscountRate"] != null)
            {
                <div class="d-flex justify-content-between mb-2 text-success">
                    <h6>İndirim Oranı</h6>
                    <h6>% @TempData["DiscountRate"]</h6>
                </div>
            }
        </div>

        <div class="pt-2">
            @if (TempData["DiscountedTotal"] != null)
            {
                <div class="d-flex justify-content-between mt-2 text-success">
                    <h5>İndirimli Toplam</h5>
                    <h5>@TempData["DiscountedTotal"] ₺</h5>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between mt-2">
                    <h5>Ödenecek Tutar</h5>
                    <h5>@ViewBag.totalPriceWithTax ₺</h5>
                </div>
            }

            <a asp-controller="Order"
               asp-action="Index"
               class="btn btn-block btn-primary font-weight-bold my-3 py-3">
                Ödeme Adımına Geç
            </a>
        </div>
    </div>
</div>