
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}


<div class="container-fluid">
    <div class="row px-xl-5">

        @if (TempData["BasketError"] != null)
        {
            <div class="alert alert-warning py-2 px-3 mb-3 text-center w-100">
                @TempData["BasketError"]
            </div>
        }

        @if (TempData["BasketSuccess"] != null)
        {
            <div class="alert alert-success py-2 px-3 mb-3 text-center w-100">
                @TempData["BasketSuccess"]
            </div>
        }

        <div class="col-lg-8 mb-4 mb-lg-0">
            @await Component.InvokeAsync("_ShoppingCartProductListComponentPartial")
        </div>

        <div class="col-lg-4">
            @await Html.PartialAsync("~/Views/Discount/ConfirmDiscountCoupon.cshtml")
        </div>

    </div>
</div>

