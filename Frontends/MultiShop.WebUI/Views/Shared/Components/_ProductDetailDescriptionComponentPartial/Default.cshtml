@model GetByIdProductDetailDto

<div class="tab-pane fade show active" id="tab-pane-1">
    <h4 class="mb-3">Ürün Detayı</h4>

    @if (Model == null)
    {
        <div class="alert alert-info">
            Bu ürün için detay bilgisi bulunmamaktadır.
        </div>
    }
    else
    {
        <p>@Model.ProductDescription</p>
    }
</div>
