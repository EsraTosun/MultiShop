@model DiscountSummaryViewModel

<div class="col-lg-4">

    @* === KUPON FORMU / DURUM MESAJLARI === *@
    @if (TempData["CouponSuccess"] == null)
    {
        <form class="mb-3" asp-controller="Discount" asp-action="ConfirmDiscountCoupon" method="post">
            <div class="input-group">
                <input type="text"
                       class="form-control border-0 p-4"
                       placeholder="Kupon Kodunuz"
                       name="CouponCode"
                       required />
                <div class="input-group-append">
                    <button class="btn btn-primary">Kuponu Uygula</button>
                </div>
            </div>
        </form>
    }
    else
    {
        <div class="alert alert-info mb-3">
            @TempData["CouponSuccess"]
        </div>
    }

    @* === HATA MESAJI === *@
    @if (TempData["CouponError"] != null)
    {
        <div class="alert alert-danger mb-3">
            @TempData["CouponError"]
        </div>
    }

    <h5 class="section-title position-relative text-uppercase mb-3">
        <span class="bg-secondary pr-3">Sipariş Özeti</span>
    </h5>

    <div class="bg-light p-30 mb-5">

        <div class="border-bottom pb-2">
            <div class="d-flex justify-content-between mb-3">
                <h6>Toplam Ürün Fiyatı</h6>
                <h6>@Model.SubTotal ₺</h6>
            </div>

            <div class="d-flex justify-content-between">
                <h6 class="font-weight-medium">KDV (%10)</h6>
                <h6 class="font-weight-medium">@Model.Tax ₺</h6>
            </div>
        </div>

        <div class="pt-2">

            <div class="d-flex justify-content-between mt-2">
                <h5>Toplam</h5>
                <h5>@Model.Total ₺</h5>
            </div>

            @* === SADECE GERÇEK İNDİRİM VARSA GÖSTER === *@
            @if (TempData["DiscountedTotal"] != null
                        && decimal.TryParse(TempData["DiscountedTotal"].ToString(), out var discountedTotal)
                        && discountedTotal > 0)
            {
                <div class="d-flex justify-content-between mt-2 text-success">
                    <h5>İndirimli Toplam</h5>
                    <h5>@discountedTotal ₺</h5>
                </div>
            }

            <a href="/Checkout"
               class="btn btn-block btn-primary font-weight-bold my-3 py-3">
                Ödeme Adımına Geç
            </a>
        </div>
    </div>
</div>
