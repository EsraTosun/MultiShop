@model SignInDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>MultiShop Login Sayfası</title>

    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/css/opensans-font.css">
    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/fonts/line-awesome/css/line-awesome.min.css">
    <link rel="stylesheet" href="https://jqueryvalidation.org/files/demo/site-demos.css">
    <link rel="stylesheet" href="~/colorlib-regform-30/css/style.css" />
</head>
<body class="form-v4">
    <div class="page-content">
        <div class="form-v4-content">
            <div class="form-left">
                <h2>MultiShop E-Ticaret</h2>
                <p class="text-1">
                    MultiShop üzerinden alışveriş yapabilmek için giriş yapmanız gerekmektedir.
                </p>
                <p class="text-2">
                    Hesabınız yoksa hemen kayıt olabilirsiniz.
                </p>
                <div class="form-left-last">
                    <a href="/Register/Index/" style="height:35px" class="account">Kayıt Ol</a>
                </div>
            </div>

            <form class="form-detail" method="post">
                <h2>MultiShop Giriş Formu</h2>

                <div class="form-row">
                    <label>Kullanıcı Adınız</label>
                    <input type="text" asp-for="Username" class="input-text" required />
                </div>

                <div class="form-row">
                    <label>Şifreniz</label>
                    <input type="password" asp-for="Password" class="input-text" required />
                </div>

                <div class="form-row-last">
                    <button class="register" style="height:35px">Giriş Yap</button>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="color:red;margin-top:10px">
                        @Html.ValidationSummary()
                    </div>
                }
            </form>
        </div>
    </div>
</body>
</html>
